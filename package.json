{
  "name": "@wyrd-company/ahp-nats",
  "version": "0.1.0",
  "description": "Agent Host Protocol NATS transport bindings.",
  "type": "module",
  "license": "MIT",
  "author": "Wyrd Company",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyrd-company/ahp-nats.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@microsoft/agent-host-protocol": "^0.3.0",
    "@nats-io/transport-node": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
